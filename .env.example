# --- Database ---
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Postgres, e.g. Vercel Postgres / Neon / Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- LinkedIn Developer App (developer.linkedin.com) ---
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# Must exactly match an "Authorized redirect URL" in your LinkedIn app's Auth tab
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"

# --- Session security ---
# Any long random string. Generate one with: openssl rand -base64 32
SESSION_SECRET=""

# --- Job APIs ---
# Adzuna: free account at https://developer.adzuna.com/
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
# RemoteOK needs no key, it's public.

# --- Cron security ---
# Any secret string. Used to protect the /api/cron/publish endpoint from public abuse.
CRON_SECRET=""
