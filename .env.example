# --- Database ---
# This project uses PostgreSQL (works both locally and on serverless hosting like Vercel).
# Get a free database in ~2 minutes at https://neon.tech, then paste its connection string here.
# You can use the same database for local dev and production, or create two separate ones.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- LinkedIn Developer App (developer.linkedin.com) ---
LINKEDIN_CLIENT_ID="your_client_id_here"
LINKEDIN_CLIENT_SECRET="your_client_secret_here"
# Must exactly match an "Authorized redirect URL" in your LinkedIn app's Auth tab
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"

# --- Session security ---
# Any long random string. Generate one with: openssl rand -base64 32
SESSION_SECRET="replace_with_a_long_random_string"

# --- Google Calendar (optional - "Sync interview to Google Calendar") ---
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Enable the "Google Calendar API" for the project, and add GOOGLE_REDIRECT_URI below
# as an "Authorized redirect URI". If these are unset, the Calendar sync button simply
# prompts the user to connect (nothing else breaks).
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Must exactly match an Authorized redirect URI in your Google OAuth client
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# --- Job APIs ---
# Jooble: free key at https://jooble.org/api/about - covers Pakistan + 68 other countries
JOOBLE_API_KEY="your_jooble_api_key"
# Adzuna: free account at https://developer.adzuna.com/ - does NOT cover Pakistan,
# but adds more results for US/UK/India/etc. Optional.
ADZUNA_APP_ID="your_adzuna_app_id"
ADZUNA_APP_KEY="your_adzuna_app_key"
# RemoteOK needs no key, it's public.

# --- Cron security ---
# Any secret string. Used to protect the /api/cron/publish endpoint from public abuse.
CRON_SECRET="replace_with_another_random_string"

# --- LinkedIn API version (optional override) ---
# LinkedIn retires API versions ~12 months after release. If posting/image
# uploads start failing with "NONEXISTENT_VERSION", set this to the current
# version (format YYYYMM) - no code change needed.
# LINKEDIN_API_VERSION="202606"

# --- AI Features (post generator, resume matcher, cover letter generator) ---
# Set ONE of these - the app auto-detects which is configured, in this priority
# order: Anthropic, then Gemini, then Groq.
# Groq (recommended): free, very fast, stable free tier - https://console.groq.com/keys
GROQ_API_KEY=""
# Gemini: free, but Google has repeatedly cut free-tier quotas (sometimes to 0
# for a given model) without much notice - https://aistudio.google.com/apikey
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash-lite"   # optional override if the default model's quota changes again
# Anthropic (Claude): paid - https://console.anthropic.com
# ANTHROPIC_API_KEY=""

# --- Encryption (Feature 6: Access Token Encryption at Rest) ---
# Required. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# --- Rate Limiting (Feature 7, optional but recommended) ---
# Free Redis at https://console.upstash.com - create a database, copy the REST URL/token.
# If left unset, rate limiting is silently skipped (app still works).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Email (Feature 9: Interview Reminders) ---
# Free at https://resend.com (100 emails/day, 3000/month free tier).
# Without a verified domain, Resend's sandbox can only send to the email
# address you signed up with - fine for personal use / testing.
RESEND_API_KEY=""
# EMAIL_FROM="Career Console <onboarding@resend.dev>"



linkedin-verify-link="https://www.linkedin.com/developers/apps/verification/875a6a2c-37c1-4f50-a2e4-60f6f3e68036
"