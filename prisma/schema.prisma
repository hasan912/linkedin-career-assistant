// Prisma schema for LinkedIn Career Assistant
// Using PostgreSQL (required for serverless hosting like Vercel - SQLite files
// don't persist on serverless infrastructure). Get a free Postgres database from
// neon.tech, Vercel Postgres, or Supabase, and set DATABASE_URL accordingly.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  linkedinSub   String   @unique
  name          String?
  email         String?
  accessToken   String
  tokenExpires  DateTime
  apiTokenHash  String?  @unique
  theme         String   @default("dark")   // dark | light
  dailyGoal     Int      @default(5)        // target applications per day
  digestEmail   Boolean  @default(true)     // weekly digest opt-in
  createdAt     DateTime @default(now())

  posts         Post[]
  applications  Application[]
}

model Post {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  content       String
  imageUrns     String[] @default([]) // LinkedIn image URNs (from the Images API) - 1 = single photo, 2+ = carousel
  scheduledFor  DateTime // when it should be published
  timeZone      String   @default("UTC") // timezone the schedule was created in, needed to compute recurrences
  repeat        String   @default("none") // none | daily | weekly
  status        String   @default("pending") // pending | posted | failed
  errorMessage  String?
  postedAt      DateTime?
  createdAt     DateTime @default(now())
}

model Application {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  jobTitle      String
  company       String
  jobUrl        String?
  status        String   @default("saved") // saved | applied | interview | offer | rejected
  notes         String?
  appliedDate   DateTime?
  interviewAt   DateTime? // scheduled interview date/time, if any
  reminderSent  Boolean  @default(false) // whether the 24h-before email reminder has gone out
  createdAt     DateTime @default(now())
}
